# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Optional: Gemini ──────────────────────────────────────────────────────────
# Full path to gemini.cmd if it's not in your PATH
# Windows example:
# GEMINI_PATH=C:\Users\YourUser\AppData\Roaming\npm\gemini.cmd

# ── Optional: Sessions ────────────────────────────────────────────────────────
# How long an idle session stays alive before being recycled (ms, default 1h)
# SESSION_TIMEOUT_MS=3600000

# ── Optional: Streaming ───────────────────────────────────────────────────────
# How often to edit the Telegram message with new chunks (ms, default 700)
# STREAM_INTERVAL_MS=700

# ── Optional: Dashboard ───────────────────────────────────────────────────────
# Port for the local web dashboard (default 7823)
# DASHBOARD_PORT=7823
